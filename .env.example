# Copy to .env.local for local development (same values as Vercel → Settings → Environment Variables).
# Get keys from Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# Server-side only — for scripts/seed-admin-user.mjs (never commit the real key)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
