# Local development — copy to .env.local (same folder as package.json)
# Use the SAME values as Vercel → Settings → Environment Variables
# Supabase Dashboard → Project Settings → API

# Required (must start with VITE_ — do not rename these)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_public_key

# Optional — server-side only for scripts/seed-admin-user.mjs (never commit the real key)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
